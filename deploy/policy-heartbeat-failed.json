{
  "displayName": "RegWatch heartbeat failed (no successful run today)",
  "combiner": "OR",
  "conditions": [{
    "displayName": "regwatch-heartbeat failed executions",
    "conditionThreshold": {
      "filter": "resource.type=\"cloud_run_job\" AND resource.labels.job_name=\"regwatch-heartbeat\" AND metric.type=\"run.googleapis.com/job/completed_execution_count\" AND metric.labels.result=\"failed\"",
      "comparison": "COMPARISON_GT",
      "thresholdValue": 0,
      "duration": "0s",
      "aggregations": [{"alignmentPeriod": "600s", "perSeriesAligner": "ALIGN_SUM"}]
    }
  }]
}
